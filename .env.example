# PostgreSQL
POSTGRES_USER=amirsalarsafaeicom
POSTGRES_PASSWORD=[REDACTED:password]
POSTGRES_DB=amirsalarsafaeicom

# Backend auth token
AUTH_TOKEN=dev-token

# Spotify (optional — leave empty if not developing music features)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_REDIRECT_URI=http://localhost:3001/callback

# Logging
RUST_LOG=info

# --- Optional: artifactory / private package mirrors ---
# Set these if you need to pull crates/npm packages through a private
# artifactory instance instead of the public registries.
# Example values:
#   CARGO_REGISTRY=sparse+https://artifactory.example.com/api/cargo/cargo-remote/
#   NPM_REGISTRY=https://artifactory.example.com/api/npm/npm-remote/
CARGO_REGISTRY=
CARGO_REGISTRY_TOKEN=
NPM_REGISTRY=
NPM_REGISTRY_TOKEN=
