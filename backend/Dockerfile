# syntax=docker/dockerfile:1
# stage 1: build
FROM rust:1-bookworm AS builder

WORKDIR /app

COPY backend/ ./backend/
COPY autogenerated/ ./autogenerated/
COPY .sqlx/ ./.sqlx/

WORKDIR /app/backend

RUN RUSTFLAGS="-C strip=symbols" cargo build --release

# stage 2: runtime
FROM debian:trixie-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app/backend/target/release/amirsalarsafaeicom-backend /usr/local/bin/
COPY backend/migrations/ /app/migrations/

# default config — override individual values via environment variables
RUN cat > /app/config.toml <<'TOML'
[database]
url = ""

[server]
host = "0.0.0.0"
port = 8000
allowed_origins = ["*"]

[image_server]
host = "0.0.0.0"
port = 3001
upload_dir = "/uploads"
TOML

RUN mkdir -p /app/spotify.d && cat > /app/spotify.toml <<'TOML'
client_id = ""
client_secret = ""
refresh_token = ""
redirect_uri = ""
TOML

ENV IMAGE_UPLOAD_DIR=/uploads
ENV IMAGE_SERVER_HOST=0.0.0.0
ENV IMAGE_SERVER_PORT=3001
ENV SQLX_OFFLINE=true

RUN mkdir -p /uploads && chmod 1777 /uploads

EXPOSE 8000
EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD pgrep -f amirsalarsafaeicom-backend || exit 1

CMD ["/usr/local/bin/amirsalarsafaeicom-backend"]
