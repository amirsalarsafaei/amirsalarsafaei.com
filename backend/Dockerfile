# syntax=docker/dockerfile:1
FROM rust:1-bookworm AS builder

ARG CARGO_REGISTRY=""
ARG CARGO_REGISTRY_TOKEN=""

RUN if [ -n "$CARGO_REGISTRY" ]; then \
      mkdir -p /usr/local/cargo && \
      printf '[source.crates-io]\nreplace-with = "artifactory"\n\n[source.artifactory]\nregistry = "%s"\n' "$CARGO_REGISTRY" > /usr/local/cargo/config.toml; \
      if [ -n "$CARGO_REGISTRY_TOKEN" ]; then \printf '\n[registries.artifactory]\ntoken = "Bearer %s"\n' "$CARGO_REGISTRY_TOKEN" >> /usr/local/cargo/config.toml; \
      fi \
    fi

WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY autogenerated/ ./autogenerated/
# The workspace lists `backend` as a member, so cargo fetch needs its manifest
# plus a target to resolve (just the manifest + a stub main.rs — keeps the
# dep-fetch layer cached until manifests change; the real source is copied next).
COPY backend/Cargo.toml ./backend/Cargo.toml
RUN mkdir -p backend/src && echo 'fn main() {}' > backend/src/main.rs

RUN cargo fetch

COPY backend/ ./backend/
COPY .sqlx/ ./.sqlx/

RUN SQLX_OFFLINE=true RUSTFLAGS="-C strip=symbols" cargo build --release -p amirsalarsafaeicom-backend


FROM debian:trixie-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl procps \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app/target/release/amirsalarsafaeicom-backend /usr/local/bin/
COPY backend/migrations/ /app/migrations/

# Seed the runtime config from the checked-in examples. These are valid as-is;
# the real secrets (DATABASE_URL, AUTH_TOKEN, SPOTIFY_*) are supplied via env
# at runtime and override these placeholders (see config.rs override_with_env).
COPY backend/config.example.toml /app/config.toml
COPY backend/spotify.example.toml /app/spotify.toml

ENV IMAGE_UPLOAD_DIR=/uploads
ENV IMAGE_SERVER_HOST=0.0.0.0
ENV IMAGE_SERVER_PORT=3001
ENV SQLX_OFFLINE=true

RUN mkdir -p /uploads && chmod 1777 /uploads

EXPOSE 8000
EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD pgrep -f amirsalarsafaeicom-backend || exit 1

CMD ["/usr/local/bin/amirsalarsafaeicom-backend"]

