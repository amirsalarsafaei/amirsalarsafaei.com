# syntax=docker/dockerfile:1
# stage 1: build
FROM rust:1-bookworm AS builder

# Optional artifactory / crates mirror.
# Pass via: --build-arg CARGO_REGISTRY=sparse+https://artifactory.example.com/api/cargo/cargo-remote/
ARG CARGO_REGISTRY=""
ARG CARGO_REGISTRY_TOKEN=""

RUN mkdir -p /usr/local/cargo && \
    if [ -n "$CARGO_REGISTRY" ]; then \
      echo "Configuring cargo to use artifactory: $CARGO_REGISTRY"; \
      printf '[source.crates-io]\nreplace-with = "artifactory"\n\n[source.artifactory]\nregistry = "%s"\n' "$CARGO_REGISTRY" \
        > /usr/local/cargo/config.toml; \
      if [ -n "$CARGO_REGISTRY_TOKEN" ]; then \
        printf '\n[registries.artifactory]\ntoken = "Bearer %s"\n' "$CARGO_REGISTRY_TOKEN" \
          >> /usr/local/cargo/config.toml; \
      fi; \
    fi

WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY backend/ ./backend/
COPY autogenerated/ ./autogenerated/
COPY .sqlx/ ./.sqlx/

ENV SQLX_OFFLINE=true
RUN RUSTFLAGS="-C strip=symbols" cargo build --release -p amirsalarsafaeicom-backend

# stage 2: runtime
FROM debian:trixie-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app/target/release/amirsalarsafaeicom-backend /usr/local/bin/
COPY backend/migrations/ /app/migrations/

# default config — override individual values via environment variables
RUN cat > /app/config.toml <<'TOML'
auth_token = "change-me"

[database]
url = ""

[server]
host = "0.0.0.0"
port = 8000
allowed_origins = ["*"]

[image_server]
host = "0.0.0.0"
port = 3001
upload_dir = "/uploads"
TOML

RUN cat > /app/spotify.toml <<'TOML'
client_id = ""
client_secret = ""
refresh_token = ""
redirect_uri = ""
TOML

ENV IMAGE_UPLOAD_DIR=/uploads
ENV IMAGE_SERVER_HOST=0.0.0.0
ENV IMAGE_SERVER_PORT=3001
ENV SQLX_OFFLINE=true

RUN mkdir -p /uploads && chmod 1777 /uploads

EXPOSE 8000
EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD pgrep -f amirsalarsafaeicom-backend || exit 1

CMD ["/usr/local/bin/amirsalarsafaeicom-backend"]
