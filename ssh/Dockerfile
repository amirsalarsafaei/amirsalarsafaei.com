# syntax=docker/dockerfile:1
FROM golang:1.25-bookworm AS builder

WORKDIR /app

# The ssh module uses a local `replace` for the generated protobuf code, so the
# generated module must be present before `go mod download`.
COPY autogenerated/go/ ./autogenerated/go/
COPY ssh/go.mod ssh/go.sum ./ssh/

WORKDIR /app/ssh
RUN go mod download

COPY ssh/ ./
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /usr/local/bin/ssh-site .

# stage 2: runtime
FROM debian:trixie-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /usr/local/bin/ssh-site /usr/local/bin/ssh-site

# Host key lives on a volume so the server identity is stable across restarts.
RUN mkdir -p /app/.ssh

ENV SSH_HOST=0.0.0.0 \
    SSH_PORT=23234 \
    SSH_HOST_KEY_PATH=/app/.ssh/id_ed25519 \
    GRPC_ADDR=backend:8000 \
    GRPC_TLS=false

EXPOSE 23234

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD pgrep -f ssh-site || exit 1

CMD ["ssh-site"]
